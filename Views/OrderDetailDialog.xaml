<Window x:Class="QalatAldhaman.Store.Admin.Views.OrderDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="{Binding OrderNumberTitle}"
        Height="720" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,16,0,8" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666666" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>
    <Grid Margin="24">
        <TextBlock Text="جارِ التحميل..."
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="16"
                   Foreground="#666" />

        <TextBlock Text="{Binding ErrorMessage}"
                   Visibility="{Binding IsError, Converter={StaticResource BoolToVis}}"
                   Foreground="#C0392B"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   MaxWidth="400" />

        <ScrollViewer Visibility="{Binding IsContentVisible, Converter={StaticResource BoolToVis}}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="بيانات الزبون" Style="{StaticResource SectionTitle}" Margin="0,0,0,8" />
                <TextBlock Text="الاسم" Style="{StaticResource FieldLabel}" />
                <TextBlock Text="{Binding Order.CustomerName}" Style="{StaticResource FieldValue}" />
                <TextBlock Text="الهاتف" Style="{StaticResource FieldLabel}" />
                <TextBlock Text="{Binding Order.PhoneNumber}" Style="{StaticResource FieldValue}" />
                <TextBlock Text="المحافظة" Style="{StaticResource FieldLabel}" />
                <TextBlock Text="{Binding Order.GovernorateName}" Style="{StaticResource FieldValue}" />

                <TextBlock Text="تفاصيل الطلب" Style="{StaticResource SectionTitle}" />
                <TextBlock Text="المنتج" Style="{StaticResource FieldLabel}" />
                <TextBlock Text="{Binding Order.ProductName}" Style="{StaticResource FieldValue}" />
                <TextBlock Text="الفئة" Style="{StaticResource FieldLabel}" />
                <TextBlock Text="{Binding Order.CategoryName}" Style="{StaticResource FieldValue}" />
                <TextBlock Text="طريقة الدفع" Style="{StaticResource FieldLabel}" />
                <TextBlock Text="{Binding PurchaseMethodText}" Style="{StaticResource FieldValue}" />
                <TextBlock Text="المبلغ الكلي" Style="{StaticResource FieldLabel}" />
                <TextBlock Text="{Binding Order.TotalPriceSnapshot, StringFormat={}{0:N0} د.ع}" Style="{StaticResource FieldValue}" />
                <StackPanel Visibility="{Binding HasInstallmentPayment, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding InstallmentPaymentLabel}" Style="{StaticResource FieldLabel}" />
                    <TextBlock Text="{Binding Order.InstallmentPaymentAmountSnapshot, StringFormat={}{0:N0} د.ع}" Style="{StaticResource FieldValue}" />
                </StackPanel>
                <TextBlock Text="تاريخ الطلب" Style="{StaticResource FieldLabel}" />
                <TextBlock Text="{Binding Order.CreatedAt}" Style="{StaticResource FieldValue}" />

                <StackPanel Visibility="{Binding HasShopFields, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="بيانات المحل" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="اسم المحل" Style="{StaticResource FieldLabel}" />
                    <TextBlock Text="{Binding Order.ShopName}" Style="{StaticResource FieldValue}" />
                    <TextBlock Text="عنوان المحل" Style="{StaticResource FieldLabel}" />
                    <TextBlock Text="{Binding Order.ShopAddress}" Style="{StaticResource FieldValue}" />
                </StackPanel>

                <StackPanel Visibility="{Binding HasHomeAddress, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="عنوان السكن" Style="{StaticResource FieldLabel}" />
                    <TextBlock Text="{Binding Order.HomeAddress}" Style="{StaticResource FieldValue}" />
                </StackPanel>

                <StackPanel Visibility="{Binding HasNearestLandmark, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="أقرب نقطة دالة" Style="{StaticResource FieldLabel}" />
                    <TextBlock Text="{Binding Order.NearestLandmark}" Style="{StaticResource FieldValue}" />
                </StackPanel>

                <StackPanel Visibility="{Binding HasCustomDescription, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="وصف المنتج المطلوب" Style="{StaticResource FieldLabel}" />
                    <TextBlock Text="{Binding Order.CustomProductDescription}" Style="{StaticResource FieldValue}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="عرض الصورة/الفيديو"
                            Command="{Binding OpenMediaCommand}"
                            Padding="12,6"
                            Margin="0,0,8,0"
                            Visibility="{Binding HasMedia, Converter={StaticResource BoolToVis}}" />
                    <Button Content="فتح بخرائط Google"
                            Command="{Binding OpenMapsCommand}"
                            Padding="12,6"
                            Margin="0,0,8,0"
                            Visibility="{Binding HasGps, Converter={StaticResource BoolToVis}}" />
                    <Button Content="فتح ملف عقد المنتج"
                            Command="{Binding OpenContractCommand}"
                            Padding="12,6"
                            Visibility="{Binding HasContract, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <TextBlock Text="تحديث الحالة" Style="{StaticResource SectionTitle}" />
                <TextBlock Text="الحالة" Style="{StaticResource FieldLabel}" />
                <ComboBox ItemsSource="{Binding StatusOptions}"
                          DisplayMemberPath="Label"
                          SelectedItem="{Binding SelectedStatus, Mode=TwoWay}"
                          Padding="6"
                          Margin="0,0,0,12" />

                <TextBlock Text="ملاحظات" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="60"
                         Padding="6"
                         Margin="0,0,0,12" />

                <TextBlock Text="{Binding SaveErrorMessage}"
                           Foreground="#C0392B"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />

                <Button Content="حفظ الحالة"
                        Command="{Binding SaveStatusCommand}"
                        IsEnabled="{Binding IsFormEnabled}"
                        Width="120"
                        Height="36"
                        HorizontalAlignment="Left"
                        Background="#1F5F5B"
                        Foreground="White"
                        BorderThickness="0" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
