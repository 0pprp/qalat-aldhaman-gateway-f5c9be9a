<Window x:Class="QalatAldhaman.Store.Admin.Views.ProductEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}"
        Height="840" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        Background="{StaticResource BrandBackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel IsEnabled="{Binding IsFormEnabled}">
                    <TextBlock Text="{Binding DialogTitle}" Style="{StaticResource SubheaderTextStyle}" Margin="0,0,0,16" />

                    <TextBlock Text="الفئة" Style="{StaticResource FieldLabelTextStyle}" />
                    <ComboBox ItemsSource="{Binding AvailableCategories}"
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                              Margin="0,0,0,12" />

                    <TextBlock Text="اسم الموديل" Style="{StaticResource FieldLabelTextStyle}" />
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                    <TextBlock Text="الوصف" Style="{StaticResource FieldLabelTextStyle}" />
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="60"
                             VerticalScrollBarVisibility="Auto" />

                    <TextBlock Text="السعر نقداً" Style="{StaticResource FieldLabelTextStyle}" />
                    <TextBox Text="{Binding CashPrice, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsCashPriceEnabled}"
                             Margin="0,0,0,12" />

                    <TextBlock Text="القسط الشهري" Style="{StaticResource FieldLabelTextStyle}" FontSize="14" Margin="0,4,0,6" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="المبلغ الكلي" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding MonthlyTotalPrice, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsMonthlyPriceEnabled}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="الدفعة الشهرية" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding MonthlyPaymentAmount, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsMonthlyPriceEnabled}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="القسط اليومي" Style="{StaticResource FieldLabelTextStyle}" FontSize="14" Margin="0,4,0,6" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="المبلغ الكلي" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding DailyTotalPrice, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsDailyPriceEnabled}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="الدفعة اليومية" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding DailyPaymentAmount, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsDailyPriceEnabled}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="SKU" Style="{StaticResource FieldLabelTextStyle}" />
                    <TextBox Text="{Binding SKU, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                    <CheckBox Content="فعّال" IsChecked="{Binding IsActive}" Margin="0,0,0,16" />

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />

                    <Separator Margin="0,0,0,12" />

                    <TextBlock Text="الصور" Style="{StaticResource SubheaderTextStyle}" FontSize="15" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding ImagesSectionNote}"
                               Style="{StaticResource CaptionTextStyle}"
                               Margin="0,0,0,8" />

                    <StackPanel IsEnabled="{Binding IsImagesSectionEnabled}">
                        <ItemsControl ItemsSource="{Binding Images}" Margin="0,0,0,8">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,8,8">
                                        <Border Width="72" Height="72" BorderBrush="{StaticResource BrandBorderBrush}" BorderThickness="1" CornerRadius="6">
                                            <Image Source="{Binding ResolvedUrl}" Stretch="UniformToFill" />
                                        </Border>
                                        <Button Content="✕"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Width="20" Height="20"
                                                Padding="0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Command="{Binding DataContext.RemoveImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="+ إضافة صورة"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding AddImageCommand}"
                                Width="140"
                                HorizontalAlignment="Left" />
                        <TextBlock Text="جارِ الرفع..."
                                   Style="{StaticResource CaptionTextStyle}"
                                   Visibility="{Binding IsUploadingImage, Converter={StaticResource BoolToVis}}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,16,0,0">
            <Button Content="حفظ"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsFormEnabled}"
                    Width="100"
                    Height="38"
                    Margin="0,0,8,0" />
            <Button Content="إغلاق" Style="{StaticResource SecondaryButtonStyle}" Click="CloseButton_Click" Width="100" Height="38" />
        </StackPanel>
    </Grid>
</Window>
