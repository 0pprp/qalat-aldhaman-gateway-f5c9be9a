<Window x:Class="QalatAldhaman.Store.Admin.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="تسجيل الدخول — لوحة تحكم قلعة الضمان"
        Height="560" Width="440"
        Icon="/Assets/app-icon.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource BrandPrimaryDarkColor}" Offset="0" />
                <GradientStop Color="{StaticResource BrandPrimaryColor}" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Border Width="360"
                Background="{DynamicResource BrandSurfaceBrush}"
                CornerRadius="14"
                Padding="32,36"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.35" BlurRadius="30" ShadowDepth="6" Direction="270" />
            </Border.Effect>

            <StackPanel IsEnabled="{Binding IsLoginEnabled}">
                <Ellipse Width="60" Height="60"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,14">
                    <Ellipse.Fill>
                        <ImageBrush Stretch="UniformToFill">
                            <ImageBrush.ImageSource>
                                <!-- الملف الأصلي لوغو كامل (شعار + نص "قلعة الضمان")؛ القص هنا يعرض الشعار فقط بدون النص لأنه سيصغر لدرجة يتعذر قراءته ببادج دائري 60px. -->
                                <CroppedBitmap SourceRect="0,0,3195,2360">
                                    <CroppedBitmap.Source>
                                        <BitmapImage UriSource="/Assets/logo.png" />
                                    </CroppedBitmap.Source>
                                </CroppedBitmap>
                            </ImageBrush.ImageSource>
                        </ImageBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <TextBlock Text="قلعة الضمان"
                           Style="{StaticResource HeaderTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,2" />
                <TextBlock Text="لوحة تحكم الأدمن"
                           Style="{StaticResource CaptionTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28" />

                <TextBlock Text="اسم المستخدم" Style="{StaticResource FieldLabelTextStyle}" />
                <TextBox x:Name="UsernameInput"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,14" />

                <TextBlock Text="كلمة المرور" Style="{StaticResource FieldLabelTextStyle}" />
                <PasswordBox x:Name="PasswordInput"
                             Margin="0,0,0,22"
                             KeyDown="PasswordInput_KeyDown" />

                <Button Content="دخول"
                        Click="LoginButton_Click"
                        Height="42"
                        FontSize="15" />

                <TextBlock Text="جارِ الدخول..."
                           Style="{StaticResource CaptionTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource DangerBrush}"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,14,0,0" />
                <TextBlock Text="{Binding InfoMessage}"
                           Foreground="{StaticResource StatusConfirmedBrush}"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
