<Window x:Class="QalatAldhaman.Store.Admin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QalatAldhaman.Store.Admin"
        xmlns:views="clr-namespace:QalatAldhaman.Store.Admin.Views"
        xmlns:vm="clr-namespace:QalatAldhaman.Store.Admin.ViewModels"
        xmlns:converters="clr-namespace:QalatAldhaman.Store.Admin.Converters"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="لوحة تحكم قلعة الضمان" Height="640" Width="1080"
        Icon="/Assets/app-icon.ico"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        Background="{DynamicResource BrandBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:NavIconConverter x:Key="NavIconConverter" />

        <!--
            نمط التنقل: ContentControl وحيد بمنطقة المحتوى، محتواه (Content) مربوط بـ CurrentViewModel
            بالـ MainViewModel. كل DataTemplate هنا يربط نوع ViewModel بالـ View المطابقة له — WPF يختار
            القالب المناسب تلقائياً حسب نوع الكائن الحالي فيضبط DataContext للـ View ضمنياً (بدون حاجة
            لأي كود يدوي بـ code-behind). هذا يضمن عرض شاشة واحدة فقط بكل لحظة، بدون أي تراكب بين الشاشات
            (المشكلة السابقة كانت عدة UserControl متراكبة بنفس الحاوية بخاصية Visibility بدل حاوية واحدة).
        -->
        <DataTemplate DataType="{x:Type vm:CategoriesViewModel}">
            <views:CategoriesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductsViewModel}">
            <views:ProductsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OrdersViewModel}">
            <views:OrdersView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReviewsViewModel}">
            <views:ReviewsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ContractsViewModel}">
            <views:ContractsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}">
            <TextBlock Style="{StaticResource HeaderTextStyle}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource BrandTextSecondaryBrush}">
                <Run Text="صفحة: " />
                <Run Text="{Binding Title, Mode=OneWay}" FontWeight="Bold" />
                <Run Text=" (قيد الإنشاء)" />
            </TextBlock>
        </DataTemplate>

        <!-- عنصر تنقل بالـ Sidebar: أيقونة + نص، تمييز واضح للمُحدَّد حالياً، تأثير Hover ناعم. -->
        <Style x:Key="NavListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="Foreground" Value="#CFE3E0" />
            <Setter Property="FontSize" Value="14.5" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="Margin" Value="10,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.BorderThickness>0,0,3,0</Border.BorderThickness>
                            <Border x:Name="AccentBar" BorderBrush="{StaticResource BrandAccentBrush}" BorderThickness="0" HorizontalAlignment="Right">
                                <ContentPresenter />
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1A6E69" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#14615C" />
                                <Setter TargetName="AccentBar" Property="BorderThickness" Value="0,0,3,0" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource BrandPrimaryDarkBrush}">
            <Grid Margin="0,28,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Ellipse Grid.Row="0"
                         Width="44" Height="44"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,8">
                    <Ellipse.Fill>
                        <ImageBrush Stretch="UniformToFill">
                            <ImageBrush.ImageSource>
                                <CroppedBitmap SourceRect="0,0,3195,2360">
                                    <CroppedBitmap.Source>
                                        <BitmapImage UriSource="/Assets/logo.png" />
                                    </CroppedBitmap.Source>
                                </CroppedBitmap>
                            </ImageBrush.ImageSource>
                        </ImageBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <TextBlock Grid.Row="1"
                           Text="قلعة الضمان"
                           Foreground="White"
                           FontSize="19"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />

                <TextBlock Grid.Row="2"
                           Text="{Binding FullName}"
                           Foreground="#9FC9C4"
                           FontSize="12.5"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,22" />

                <ListBox Grid.Row="3"
                         ItemsSource="{Binding NavItems}"
                         SelectedItem="{Binding SelectedNavItem, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource NavListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="{Binding Converter={StaticResource NavIconConverter}}"
                                                         Width="19" Height="19"
                                                         Margin="10,0,0,0"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="{Binding}"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="4"
                        Command="{Binding ToggleThemeCommand}"
                        Style="{StaticResource SidebarActionButtonStyle}"
                        Margin="16,8,16,0"
                        Height="38">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="{Binding ThemeToggleIcon}"
                                                 Width="17" Height="17"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ThemeToggleLabel}" VerticalAlignment="Center" Foreground="White" />
                    </StackPanel>
                </Button>

                <Button Grid.Row="5"
                        Content="تسجيل خروج"
                        Command="{Binding LogoutCommand}"
                        Style="{StaticResource SidebarActionButtonStyle}"
                        Margin="16,8,16,0"
                        Height="38" />
            </Grid>
        </Border>

        <!-- Content area: عنصر واحد فقط يُعرض بكل لحظة -->
        <Border Grid.Column="1" Background="{DynamicResource BrandBackgroundBrush}">
            <ContentControl Content="{Binding CurrentViewModel}" Focusable="False" />
        </Border>
    </Grid>
</Window>
