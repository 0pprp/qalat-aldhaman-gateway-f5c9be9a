<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        قيم الوضع الفاتح (الافتراضي) للألوان التي تتغيّر حسب الوضع: الخلفية/السطح/الحدود/النص،
        بالإضافة لحالات الـ hover/zebra/selection بالجداول. يُستبدَل هذا الملف بـ Theme.Dark.xaml
        وقت التشغيل عبر ThemeService — لهذا كل مستهلك لهذي المفاتيح بالمشروع يجب أن يستخدم
        DynamicResource (وليس StaticResource) ليتحدّث فوراً عند تبديل الوضع.
    -->

    <Color x:Key="BrandBackgroundColor">#F7F9F8</Color>
    <Color x:Key="BrandSurfaceColor">#FFFFFF</Color>
    <Color x:Key="BrandBorderColor">#E1E6E5</Color>
    <Color x:Key="BrandTextPrimaryColor">#1B2A28</Color>
    <Color x:Key="BrandTextSecondaryColor">#6B7B79</Color>

    <SolidColorBrush x:Key="BrandBackgroundBrush" Color="{StaticResource BrandBackgroundColor}" />
    <SolidColorBrush x:Key="BrandSurfaceBrush" Color="{StaticResource BrandSurfaceColor}" />
    <SolidColorBrush x:Key="BrandBorderBrush" Color="{StaticResource BrandBorderColor}" />
    <SolidColorBrush x:Key="BrandTextPrimaryBrush" Color="{StaticResource BrandTextPrimaryColor}" />
    <SolidColorBrush x:Key="BrandTextSecondaryBrush" Color="{StaticResource BrandTextSecondaryColor}" />

    <!-- حالات الجداول/الأزرار الثانوية -->
    <SolidColorBrush x:Key="BrandControlHoverBrush" Color="#F0F3F2" />
    <SolidColorBrush x:Key="BrandRowHoverBrush" Color="#E8F0EF" />
    <SolidColorBrush x:Key="BrandZebraBrush" Color="#F3F6F5" />
    <SolidColorBrush x:Key="BrandSelectedBrush" Color="#D9E9E7" />

</ResourceDictionary>
