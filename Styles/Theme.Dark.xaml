<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        قيم الوضع الداكن — نفس المفاتيح تماماً بقيم مغايرة. خلفية/سطح داكنان بتدرّج تيلي خفيف
        (وليس أسود صافٍ) ليبقى متوافقاً مع هوية العلامة التجارية، ونص فاتح بتباين عالٍ.
    -->

    <Color x:Key="BrandBackgroundColor">#12201E</Color>
    <Color x:Key="BrandSurfaceColor">#1A2C2A</Color>
    <Color x:Key="BrandBorderColor">#2C4340</Color>
    <Color x:Key="BrandTextPrimaryColor">#ECF3F1</Color>
    <Color x:Key="BrandTextSecondaryColor">#9FB3B0</Color>

    <SolidColorBrush x:Key="BrandBackgroundBrush" Color="{StaticResource BrandBackgroundColor}" />
    <SolidColorBrush x:Key="BrandSurfaceBrush" Color="{StaticResource BrandSurfaceColor}" />
    <SolidColorBrush x:Key="BrandBorderBrush" Color="{StaticResource BrandBorderColor}" />
    <SolidColorBrush x:Key="BrandTextPrimaryBrush" Color="{StaticResource BrandTextPrimaryColor}" />
    <SolidColorBrush x:Key="BrandTextSecondaryBrush" Color="{StaticResource BrandTextSecondaryColor}" />

    <!-- حالات الجداول/الأزرار الثانوية -->
    <SolidColorBrush x:Key="BrandControlHoverBrush" Color="#243634" />
    <SolidColorBrush x:Key="BrandRowHoverBrush" Color="#223432" />
    <SolidColorBrush x:Key="BrandZebraBrush" Color="#182726" />
    <SolidColorBrush x:Key="BrandSelectedBrush" Color="#2A4B47" />

</ResourceDictionary>
