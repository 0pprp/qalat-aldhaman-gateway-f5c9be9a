<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        هوية الألوان الثابتة (لا تتغيّر بين الوضع الفاتح والداكن): تيل داكن أساسي + ذهبي/كهرماني
        للتمييز، مطابقة لموقع قلعة الضمان العام. ألوان الخلفية/السطح/الحدود/النص (التي تتغيّر
        فعلاً حسب الوضع) انتقلت إلى Styles/Theme.Light.xaml و Styles/Theme.Dark.xaml — يُستبدَل
        أحدهما بالآخر وقت التشغيل عبر ThemeService.
    -->

    <Color x:Key="BrandPrimaryDarkColor">#0D4F4B</Color>
    <Color x:Key="BrandPrimaryColor">#0F5B57</Color>
    <Color x:Key="BrandPrimaryLightColor">#1F7A74</Color>
    <Color x:Key="BrandAccentColor">#D4A017</Color>
    <Color x:Key="BrandAccentLightColor">#E0A82E</Color>

    <SolidColorBrush x:Key="BrandPrimaryDarkBrush" Color="{StaticResource BrandPrimaryDarkColor}" />
    <SolidColorBrush x:Key="BrandPrimaryBrush" Color="{StaticResource BrandPrimaryColor}" />
    <SolidColorBrush x:Key="BrandPrimaryLightBrush" Color="{StaticResource BrandPrimaryLightColor}" />
    <SolidColorBrush x:Key="BrandAccentBrush" Color="{StaticResource BrandAccentColor}" />
    <SolidColorBrush x:Key="BrandAccentLightBrush" Color="{StaticResource BrandAccentLightColor}" />

    <!-- ألوان الحالة (تبقى كما هي مبنية أصلاً — موحّدة هنا للاستخدام العام إن احتيج). -->
    <SolidColorBrush x:Key="StatusPendingBrush" Color="#B8860B" />
    <SolidColorBrush x:Key="StatusContactedBrush" Color="#2E74B5" />
    <SolidColorBrush x:Key="StatusConfirmedBrush" Color="#1E7E34" />
    <SolidColorBrush x:Key="StatusRejectedBrush" Color="#C0392B" />
    <SolidColorBrush x:Key="StatusCompletedBrush" Color="#1F6B65" />

    <SolidColorBrush x:Key="DangerBrush" Color="#C0392B" />
    <SolidColorBrush x:Key="DangerLightBrush" Color="#E74C3C" />

</ResourceDictionary>
