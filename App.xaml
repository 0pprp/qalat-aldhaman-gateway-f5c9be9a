<Application x:Class="QalatAldhaman.Store.Admin.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:QalatAldhaman.Store.Admin"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Teal" SecondaryColor="Amber" />
                <ResourceDictionary Source="Styles/Colors.xaml" />
                <!-- الوضع الافتراضي عند أول تشغيل بدون تفضيل محفوظ: فاتح. ThemeService.Initialize()
                     يستبدل هذا القاموس بـ Theme.Dark.xaml وقت الإقلاع إن كان التفضيل المحفوظ داكناً،
                     قبل ظهور أي نافذة (لا وميض مرئي). -->
                <ResourceDictionary Source="Styles/Theme.Light.xaml" />
                <ResourceDictionary Source="Styles/Typography.xaml" />
                <ResourceDictionary Source="Styles/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
